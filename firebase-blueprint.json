{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A single trading transaction record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "direction": { "type": "string", "enum": ["LONG", "SHORT"] },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "pnl": { "type": "number" },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "strategyId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "symbol", "entryPrice", "quantity", "direction", "status", "entryTime"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "A daily or trade-specific journal entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "tradeId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "Strategy": {
      "title": "Strategy",
      "description": "A trading strategy definition.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["userId", "name"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Aggregated performance statistics for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalProfit": { "type": "number" },
        "winRate": { "type": "number" },
        "totalTrades": { "type": "number" },
        "equityCurve": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "date-time" },
              "value": { "type": "number" }
            }
          }
        }
      },
      "required": ["userId"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "User preferences and goals.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currency": { "type": "string" },
        "dailyGoal": { "type": "number" },
        "weeklyGoal": { "type": "number" },
        "notifications": {
          "type": "object",
          "properties": {
            "tp_hit": { "type": "boolean" },
            "sl_hit": { "type": "boolean" },
            "goal_reached": { "type": "boolean" },
            "daily_summary": { "type": "boolean" }
          }
        }
      },
      "required": ["userId", "currency", "dailyGoal", "weeklyGoal", "notifications"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of user trades."
    },
    "/journal_entries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Collection of journal entries."
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Collection of trading strategies."
    },
    "/user_stats/{userId}": {
      "schema": "UserStats",
      "description": "User performance statistics."
    },
    "/settings/{settingId}": {
      "schema": "UserSettings",
      "description": "User settings and preferences."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
