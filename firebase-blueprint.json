{
  "entities": {
    "Trade": {
      "title": "Trade",
      "description": "A single trading transaction record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "symbol": { "type": "string" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "direction": { "type": "string", "enum": ["LONG", "SHORT"] },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "pnl": { "type": "number" },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "strategyId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isDemo": { "type": "boolean" }
      },
      "required": ["userId", "symbol", "entryPrice", "quantity", "direction", "status", "entryTime"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "A daily or trade-specific journal entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "tradeId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isDemo": { "type": "boolean" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "Strategy": {
      "title": "Strategy",
      "description": "A trading strategy definition.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "string" },
        "notes": { "type": "string" },
        "isDemo": { "type": "boolean" }
      },
      "required": ["userId", "name"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Aggregated performance statistics for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalProfit": { "type": "number" },
        "winRate": { "type": "number" },
        "totalTrades": { "type": "number" },
        "equityCurve": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "date-time" },
              "value": { "type": "number" }
            }
          }
        }
      },
      "required": ["userId"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "User preferences and goals.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currency": { "type": "string" },
        "dailyGoal": { "type": "number" },
        "weeklyGoal": { "type": "number" },
        "notifications": {
          "type": "object",
          "properties": {
            "tp_hit": { "type": "boolean" },
            "sl_hit": { "type": "boolean" },
            "goal_reached": { "type": "boolean" },
            "daily_summary": { "type": "boolean" }
          }
        }
      },
      "required": ["userId", "currency", "dailyGoal", "weeklyGoal", "notifications"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "TradingAccount": {
      "title": "Trading Account",
      "description": "A specific trading account (MT4/MT5).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "name": { "type": "string" },
        "broker": { "type": "string" },
        "currency": { "type": "string" },
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "accountNumber", "currency"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single persistent AI chat message.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": "TradingAccount",
      "description": "Collection of user trading accounts."
    },
    "/users/{userId}/accounts/{accountId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of user trades."
    },
    "/users/{userId}/accounts/{accountId}/journal_entries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Collection of journal entries."
    },
    "/users/{userId}/accounts/{accountId}/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Collection of trading strategies."
    },
    "/users/{userId}/accounts/{accountId}/settings/{settingId}": {
      "schema": "UserSettings",
      "description": "Account-specific settings and preferences."
    },
    "/users/{userId}/accounts/{accountId}/transactions/{transactionId}": {
      "schema": "object",
      "description": "Financial transactions for the account."
    },
    "/chat_history/{messageId}": {
      "schema": "ChatMessage",
      "description": "Persistent AI chat history for users."
    },
    "/user_stats/{userId}": {
      "schema": "UserStats",
      "description": "User performance statistics."
    }
  }
}
