rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin logic - Only use email for initialization or if explicitly required
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "franklinmburu05@gmail.com" || 
        request.auth.token.email == "franklinvidal198@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128));
    }

    function isValidAccount(data, userId) {
      return data.userId == userId &&
             data.accountNumber is string && data.accountNumber.size() <= 64 &&
             data.currency is string && data.currency.size() <= 10 &&
             (!('name' in data) || (data.name is string && data.name.size() <= 128));
    }

    function isValidTrade(data, userId, accountId) {
      return data.userId == userId &&
             data.accountId == accountId &&
             data.symbol is string && data.symbol.size() <= 20 &&
             data.entryPrice is number &&
             data.quantity is number &&
             data.direction in ['LONG', 'SHORT'] &&
             data.status in ['OPEN', 'CLOSED'] &&
             (!('pnl' in data) || data.pnl is number) &&
             (!('entryTime' in data) || data.entryTime is string) &&
             (!('exitTime' in data) || data.exitTime is string);
    }

    function isValidJournalEntry(data, userId, accountId) {
      return data.userId == userId &&
             data.accountId == accountId &&
             data.content is string && data.content.size() <= 10000 &&
             (!('mood' in data) || data.mood is string) &&
             (!('tags' in data) || data.tags is list);
    }

    function isValidStrategy(data, userId, accountId) {
      return data.userId == userId &&
             data.name is string && data.name.size() <= 128 &&
             (!('rules' in data) || data.rules is string);
    }

    function isValidSettings(data, userId) {
      return data.userId == userId &&
             data.currency is string &&
             data.dailyGoal is number &&
             data.weeklyGoal is number;
    }

    // --- Match Rules ---
    
    // Collection Group Rules for Admins
    match /{path=**}/trades/{tradeId} {
      allow read: if isAdmin();
    }
    match /{path=**}/strategies/{strategyId} {
      allow read: if isAdmin();
    }
    match /{path=**}/accounts/{accountId} {
      allow read: if isAdmin();
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) && 
                    (isAdmin() || incoming().role == existing().role);
      allow delete: if isAdmin();

      // 2. Nested Accounts Collection (The Master Gate)
      match /accounts/{accountId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(accountId) && isValidAccount(incoming(), userId);
        allow update: if isOwner(userId) && isValidAccount(incoming(), userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'broker', 'balance', 'equity', 'lastUpdate', 'lastSync']);
        allow delete: if isOwner(userId);

        // 3. Nested Account Resources
        match /trades/{tradeId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidTrade(incoming(), userId, accountId);
          allow update: if isOwner(userId) && isValidTrade(incoming(), userId, accountId) && (
            // Action: Close Trade
            (existing().status == 'OPEN' && incoming().status == 'CLOSED' && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'exitPrice', 'exitTime', 'pnl', 'notes', 'tags'])) ||
            // Action: Edit Notes/Tags
            (incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'tags', 'strategyId']))
          );
          allow delete: if isOwner(userId);
        }

        match /journal_entries/{entryId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) && isVerified()) && isValidJournalEntry(incoming(), userId, accountId);
          allow update: if (isOwner(userId) && isVerified()) && isValidJournalEntry(incoming(), userId, accountId);
          allow delete: if (isOwner(userId) && isVerified());
        }

        match /strategies/{strategyId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) && isVerified()) && isValidStrategy(incoming(), userId, accountId);
          allow update: if (isOwner(userId) && isVerified()) && isValidStrategy(incoming(), userId, accountId);
          allow delete: if (isOwner(userId) && isVerified());
        }

        match /settings/{settingId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) && isVerified()) && isValidSettings(incoming(), userId);
          allow update: if (isOwner(userId) && isVerified()) && isValidSettings(incoming(), userId);
          allow delete: if (isOwner(userId) && isVerified());
        }

        match /transactions/{transactionId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) && isVerified());
          allow update, delete: if isAdmin();
        }
      }
    }

    // Global Collections (Legacy support or needed non-nested data)
    match /user_stats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /chat_history/{messageId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
