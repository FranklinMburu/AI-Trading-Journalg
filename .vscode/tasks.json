{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TradeFlow: Install & Setup",
      "type": "shell",
      "command": "${workspaceFolder}/setup.sh",
      "windows": {
        "command": "${workspaceFolder}/setup.bat"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "TradeFlow: Run Diagnostics",
      "type": "npm",
      "script": "check",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "TradeFlow: Start Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        },
        "background": {
            "activeOnStart": true,
            "beginsPattern": "Initializing Express app...",
            "endsPattern": "Server running on http://localhost:3000"
        }
      }
    }
  ]
}
